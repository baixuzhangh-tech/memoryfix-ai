# PayPal Checkout (replaces Paddle)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
VITE_PAYPAL_ENVIRONMENT=sandbox
# Legacy Paddle vars (kept for backward-compat with existing DB records)
# VITE_PADDLE_CLIENT_TOKEN=test_your_client_side_token
# VITE_PADDLE_ENVIRONMENT=sandbox
# VITE_PADDLE_HUMAN_RESTORE_PRICE_ID=pri_your_human_restore_price_id
# VITE_PADDLE_LOCAL_PACK_PRICE_ID=pri_your_local_pack_price_id
VITE_HUMAN_RESTORE_CONTACT_EMAIL=hello@artgen.site
SITE_URL=https://artgen.site
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_HUMAN_RESTORE_ORIGINALS_BUCKET=human-restore-originals
SUPABASE_HUMAN_RESTORE_RESULTS_BUCKET=human-restore-results
AI_RESTORE_PROVIDER=fal
HUMAN_RESTORE_AUTO_PROCESS_AFTER_UPLOAD=true
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODERATION_MODEL=omni-moderation-latest
HUMAN_RESTORE_IMAGE_MODERATION=true
HUMAN_RESTORE_IMAGE_MODERATION_FAIL_OPEN=false
OPENAI_IMAGE_EDIT_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=png
FAL_KEY=your_fal_key
FAL_RESTORE_MODEL=fal-ai/image-editing/photo-restoration
FAL_RESTORE_ENABLE_CODEFORMER_PIPELINE=true
FAL_RESTORE_MAX_POLLS=12
FAL_RESTORE_POLL_INTERVAL_MS=2000
FAL_RESTORE_GUIDANCE_SCALE=3.5
FAL_RESTORE_NUM_INFERENCE_STEPS=30
FAL_RESTORE_OUTPUT_FORMAT=jpeg
FAL_RESTORE_SAFETY_TOLERANCE=2
FAL_RESTORE_INCLUDE_PROMPT=false
REPLICATE_API_TOKEN=your_replicate_api_token
REPLICATE_DEFAULT_PRESET=codeformer
REPLICATE_CODEFORMER_MODEL=lucataco/codeformer:78f2bab438ab0ffc85a68cdfd316a2ecd3994b5dd26aa6b3d203357b45e5eb1b
REPLICATE_CODEFORMER_FIDELITY=0.7
REPLICATE_CODEFORMER_BACKGROUND_ENHANCE=true
REPLICATE_CODEFORMER_FACE_UPSAMPLE=true
REPLICATE_CODEFORMER_UPSCALE=2
REPLICATE_GFPGAN_MODEL=tencentarc/gfpgan:0fbacf7afc6c144e5be9767cff80f25aff23e52b0708f17e20f9879b2f21516c
REPLICATE_GFPGAN_SCALE=2
REPLICATE_GFPGAN_VERSION=v1.4
RESEND_API_KEY=your_resend_api_key
# PayPal server-side
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
# Legacy Paddle server-side vars (kept for backward-compat with existing DB records)
# PADDLE_API_KEY=your_paddle_api_key
# PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
# PADDLE_HUMAN_RESTORE_PRICE_ID=pri_your_human_restore_price_id
# PADDLE_LOCAL_PACK_PRICE_ID=pri_your_local_pack_price_id
# PADDLE_ENVIRONMENT=sandbox
HUMAN_RESTORE_INBOX=you@example.com
HUMAN_RESTORE_FROM_EMAIL="MemoryFix AI <onboarding@resend.dev>"
HUMAN_RESTORE_SUPPORT_EMAIL=support@example.com
HUMAN_RESTORE_UPLOAD_TOKEN_SECRET=replace_with_a_long_random_secret
HUMAN_RESTORE_ADMIN_TOKEN=replace_with_a_long_private_admin_token
HUMAN_RESTORE_DOWNLOAD_URL_EXPIRES_SECONDS=604800
CRON_SECRET=replace_with_a_long_private_cron_secret
# Umami analytics (growth funnel). Leave blank to disable the
# tracker script entirely — all trackProductEvent() calls degrade
# to no-ops for Umami while Vercel Analytics continues to work.
# Get the website id from https://cloud.umami.is after adding
# artgen.site as a website there.
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
